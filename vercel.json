{
  "name": "juego-habilidades",
  "version": 2,
  "buildCommand": "echo 'Sitio estático - no requiere build'",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}